<h1>Users</h1>

<table class="table">
  <thead>
    <tr>
      <th>id</th>
      <th>email</th>
      <th>name</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.id %></td>
        <td><%= user.email %></td>
        <td><%= user.name %></td>
        <td>
          <%= link_to "delete", admin_user_path(user), method: :delete, data: { confirm: "本当に削除しますか" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
