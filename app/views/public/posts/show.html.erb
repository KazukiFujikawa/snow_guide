<script>
  $('#raty').raty({
    starOn: "<%= asset_path("star-on.png") %>",
    starOff: "<%= asset_path("star-off.png") %>",
    scoreName: "review[evaluation]",
    score: "<%= @review.evaluation %>"
  });

  $('#raty_ave').raty({
    starOn: "<%= asset_path("star-on.png") %>",
    starOff: "<%= asset_path("star-off.png") %>",
    starHalf: "<%= asset_path("star-half.png") %>",
    readOnly: true,
    score: "<%= @average %>"        
  });
</script>