<h1>投稿詳細<span id="raty_ave" class="ml-4"></span></h1>

<table class="table">
  <tbody>
    <tr>  
      <th>名称</th>
      <td><%= @post.name %></td>
    </tr>
    <tr>  
      <th>所在地</th>
      <td><%= @post.address %></td>
    </tr>
    <tr>  
      <th>詳細情報</th>
      <td><%= simple_format @post.explanation %></td>
    </tr>
    <tr>  
      <th>投稿日時</th>
      <td><%= @post.created_at.to_s %></td>
    </tr>
  </tbody>
</table>

<%= link_to "編集", edit_post_path(@post), class: "btn btn-warning" %>
<%= link_to "一覧に戻る", posts_path, class: "btn btn-secondary" %>

<div class="row">
  <div class="col-md-6">
    <h2>レビュー</h2>

    <%= form_with model: @review,
                  url: post_reviews_path(@post),
                  method: :post,
                  local: true do |f| %>
      <%= f.label :evaluation, "⭐️の数で評価" %>
      <div class="d-flex">
        <div class="mr-2">
          <div id="raty"></div>
        </div>
        <%= f.submit "投稿する", class: "btn btn-primary btn-sm" %>
        </div>
    <% end %>
  </div>

  <div class="col-md-6">
    <%= form_with model: [@post, @comment] do |f| %>
      <%= f.label :body, "コメントを書く" %>
      <%= f.text_area :body, rows: 5, class: "form-control" %>
      <%= f.submit "コメント", class: "btn btn-primary btn-sm mt-2" %>
    <% end %>
  </div>
</div>

<h2>コメント一覧</h2>

<table class="table">
  <thead>
    <tr>
      <th>コメント</th>
      <th>投稿者</th>
      <th></th>
    </tr>
  </thed>
  <tbody>
    <% @comments.each do |comment| %>
      <tr>
        <td><%= comment.body %></td>
        <td><%= comment.user.name %></td>
        <td>
          <% if comment.user == current_user %>
            <%= link_to "削除", post_comment_path(@post, comment),
                                method: :delete,
                                data: { confirm: "本当に削除しますか" } %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<script>
  $('#raty').raty({
    starOn: "<%= asset_path("star-on.png") %>",
    starOff: "<%= asset_path("star-off.png") %>",
    scoreName: "review[evaluation]",
    score: "<%= @review.evaluation %>"
  });

  $('#raty_ave').raty({
    starOn: "<%= asset_path("star-on.png") %>",
    starOff: "<%= asset_path("star-off.png") %>",
    starHalf: "<%= asset_path("star-half.png") %>",
    readOnly: true,
    score: "<%= @average %>"        
  });
</script>